[include]
	path = ~/.config/git/user
[include]
	path = ~/.config/git/catppuccin.gitconfig
[gpg]
  format = ssh
[column]
  ui = auto
[branch]
  sort = -committerdate
[tag]
  sort = version:refname
[init]
  defaultBranch = main
[diff]
  algorithm = histogram
  colorMoved = plain
  mnemonicPrefix = true
  renames = true
	tool = bcomp
[push]
  default = simple
  autoSetupRemote = true
  # followTags = true
[pull]
  rebase = false
[fetch]
  prune = true
  # pruneTags = true
  all = true
[help]
  autocorrect = prompt
  verbose = true
[rerere]
  enabled = true
  autoupdate = true
[core]
  excludesfile = ~/.gitignore
[rebase]
  autoSquash = true
  autoStash = true
  updateRefs = true
[url "git@github.com:"]
	insteadOf = https://github.com/
